# Copy to `.env.external` and fill in real values (that file is gitignored).
# Point these at your externally hosted Postgres connection details.
# If your provider offers a pooled connection, use a SESSION-mode endpoint
# (typically port 5432), not a transaction-mode pooler — the latter breaks
# Hibernate/Flyway prepared statements.

SPRING_PROFILES_ACTIVE=external
EXTERNAL_DB_HOST=your-db-host
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=postgres
EXTERNAL_DB_USER=your-db-user
EXTERNAL_DB_PASSWORD=your-db-password
# EXTERNAL_DB_SSLMODE=require
